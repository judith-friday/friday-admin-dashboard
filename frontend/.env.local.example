# Frontend Environment Variables

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL (usually same as API URL)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Environment
NEXT_PUBLIC_ENV=development

# ──────────────────────────────────────────────────────────────────
# Optional — dev-only demo login button
#
# When both are set AND NODE_ENV === 'development', the login screen
# shows a "Sign in as demo user" button that fills these credentials
# and submits the real /api/auth/login flow. Static export bakes
# NODE_ENV at build time, so the button never appears in production
# Vercel builds.
# ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=
